# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://admin:password@localhost:5432/codeinterview

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379

# ─── Authentication ────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=super-secret-nextauth-key-min-32-chars-long-here
JWT_SECRET=separate-jwt-secret-for-websocket-auth
INTERVIEW_SECRET=hmac-secret-for-invite-tokens

# ─── OAuth Providers ───────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

# ─── WebSocket ────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_PORT=3001
WS_CORS_ORIGIN=http://localhost:3000

# ─── TURN/STUN (WebRTC) ────────────────────────────────────
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
NEXT_PUBLIC_TURN_USER=turnuser
NEXT_PUBLIC_TURN_PASS=turnpassword
TURN_AUTH_SECRET=coturn-static-auth-secret

# ─── Docker Execution Service ──────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
EXECUTION_TIMEOUT_MS=10000
EXECUTION_MEMORY_LIMIT_MB=256
EXECUTION_CPU_QUOTA=50000
CONTAINER_POOL_SIZE=3

# ─── Storage (S3 / MinIO) ──────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=codeinterview-recordings
S3_REGION=us-east-1

# ─── AI Hints (optional) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Email (invites + notifications) ───────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxx
FROM_EMAIL=noreply@codeinterview.example.com

# ─── Monitoring ────────────────────────────────────────────
PROMETHEUS_PORT=9090
LOG_LEVEL=info
